rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // - uid: string (required)
    // - email: string (required)
    // - displayName: string
    // - studyArea: string
    // - dailyGoalHours: number
    //
    // Collection: subjects
    // - userId: string (required)
    // - name: string (required)
    //
    // Collection: topics
    // - userId: string (required)
    // - subjectId: string (required)
    // - status: string
    //
    // Collection: sessions
    // - userId: string (required)
    // - durationMinutes: number
    //
    // Collection: revisions
    // - userId: string (required)
    // - topicId: string
    //
    // Collection: exams
    // - userId: string (required)
    // - score: number
    //
    // Collection: editais
    // - userId: string (required)
    // - concurso: string (required)
    // - cargo: string (required)
    // - data: object (required)
    // - createdAt: string (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isUserDocOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidSubject(data) {
      return data.userId == request.auth.uid &&
             data.name is string && data.name.size() < 100;
    }

    function isValidTopic(data) {
      return data.userId == request.auth.uid &&
             data.name is string && data.name.size() < 200;
    }

    function isValidSession(data) {
      return data.userId == request.auth.uid &&
             data.durationMinutes is number;
    }

    function isValidEdital(data) {
      return data.userId == request.auth.uid &&
             data.concurso is string && data.concurso.size() < 200 &&
             data.cargo is string && data.cargo.size() < 200 &&
             data.data is map &&
             data.createdAt is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isUserDocOwner(userId);
      allow create: if isUserDocOwner(userId) && isValidUser(request.resource.data);
      allow update: if isUserDocOwner(userId) && isValidUser(request.resource.data);
    }

    match /subjects/{subjectId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidSubject(request.resource.data);
      allow update: if isDocOwner() && isValidSubject(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /topics/{topicId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidTopic(request.resource.data);
      allow update: if isDocOwner() && isValidTopic(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /sessions/{sessionId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidSession(request.resource.data);
      allow update: if isDocOwner() && isValidSession(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /revisions/{revisionId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && request.resource.data.userId == request.auth.uid;
      allow delete: if isDocOwner();
    }

    match /exams/{examId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && request.resource.data.userId == request.auth.uid;
      allow delete: if isDocOwner();
    }

    match /editais/{editalId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidEdital(request.resource.data);
      allow update: if isDocOwner() && isValidEdital(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
